// Prisma schema — defines User, ActivationCode, Goal, and Conversation models backed by PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserStatus {
  PENDING
  ACTIVE
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum ConversationRole {
  USER
  ASSISTANT
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  line_user_id String?    @unique
  status       UserStatus @default(PENDING)
  timezone     String     @default("Asia/Taipei")
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt

  activation_codes ActivationCode[]
  goals            Goal[]
  conversations    Conversation[]

  @@map("users")
}

model ActivationCode {
  id         String   @id @default(cuid())
  code       String   @unique
  user_id    String
  used       Boolean  @default(false)
  expires_at DateTime
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("activation_codes")
}

model Goal {
  id          String     @id @default(cuid())
  user_id     String
  title       String
  description String?
  status      GoalStatus @default(ACTIVE)
  due_date    DateTime?
  remind_at   DateTime?
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([user_id, status])
  @@map("goals")
}

model Conversation {
  id         String           @id @default(cuid())
  user_id    String
  role       ConversationRole
  content    String
  created_at DateTime         @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([user_id, created_at])
  @@map("conversations")
}
